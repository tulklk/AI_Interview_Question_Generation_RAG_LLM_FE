# Backend API (required for apiClient). No trailing slash.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# RAG / LLM service. No trailing slash.
NEXT_PUBLIC_RAG_BASE_URL=https://iqgsrag.cloud
NEXT_PUBLIC_RAG_API_KEY=

# Relative to API base URL. POST body: { "refreshToken": "<jwt>" }
# Response JSON should include accessToken (or access_token / token) and optionally refreshToken.
NEXT_PUBLIC_AUTH_REFRESH_PATH=/auth/refresh

# Where to send users when refresh fails or token is invalid
NEXT_PUBLIC_APP_LOGIN_PATH=/login
