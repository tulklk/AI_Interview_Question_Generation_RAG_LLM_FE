# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# OS generated files (Windows)
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# IDE - VSCode (local/personal settings only)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# IDE - JetBrains (WebStorm, IntelliJ...)
.idea/
*.iml
*.iws

# Cursor AI editor
.cursor/

# Turborepo / build cache
.turbo/
.cache/

# Storybook
storybook-static/

# Playwright / E2E tests
/test-results/
/playwright-report/
/playwright/.cache/
